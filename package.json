{
  "name": "nest-template",
  "author": "Jianvey <Jianvey@outlook.com> (https://github.com/Jianvey)",
  "engines": {
    "node": ">=24.14.0"
  },
  "scripts": {
    "start": "nest start --watch",
    "production": "NODE_ENV=production node dist/main",
    "pm2": "pm2 reset all && pm2 startOrRestart pm2.config.json --env production && pm2 save",
    "deploy-setup": "pm2 deploy pm2.config.json production setup",
    "deploy": "pm2 deploy pm2.config.json production --force",
    "prisma:reset": "prisma migrate reset",
    "prisma:dev": "prisma migrate dev && prisma generate",
    "prisma:deploy": "NODE_ENV=production prisma migrate deploy",
    "package:update": "pnpm update --latest",
    "build": "nest build",
    "type-check": "tsc -p tsconfig.build.json --noEmit",
    "lint": "eslint --fix",
    "prettier": "prettier --write . --ignore-unknown",
    "commit": "git-cz",
    "husky-install": "npx husky init && printf 'npm run type-check || exit 1\\n' > .husky/pre-commit && echo \"npx --no -- commitlint --edit \\$1\" > .husky/commit-msg",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx,mjs,cjs}": ["eslint --fix", "prettier --write"],
    "*.{json,md,yml,yaml,prisma}": ["prettier --write"]
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1028.0",
    "@keyv/redis": "^5.1.6",
    "@nest-lab/throttler-storage-redis": "^1.2.0",
    "@nestjs/axios": "^4.0.1",
    "@nestjs/bullmq": "^11.0.4",
    "@nestjs/cache-manager": "^3.1.0",
    "@nestjs/common": "^11.1.18",
    "@nestjs/config": "^4.0.4",
    "@nestjs/core": "^11.1.18",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^11.1.18",
    "@nestjs/schedule": "^6.1.1",
    "@nestjs/swagger": "^11.2.7",
    "@nestjs/throttler": "^6.5.0",
    "@prisma/adapter-mariadb": "^7.7.0",
    "@prisma/client": "^7.7.0",
    "agentkeepalive": "^4.6.0",
    "bcrypt": "^6.0.0",
    "bullmq": "^5.73.3",
    "cache-manager": "^7.2.8",
    "cacheable": "^2.3.4",
    "chalk": "^5.6.2",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "compression": "^1.8.1",
    "cookie-parser": "^1.4.7",
    "dayjs": "^1.11.20",
    "express": "^5.2.1",
    "geoip-lite": "^2.0.1",
    "handlebars": "^4.7.9",
    "helmet": "^8.1.0",
    "ioredis": "^5.10.1",
    "ip2region.js": "^3.1.8",
    "joi": "^18.1.2",
    "keyv": "^5.6.0",
    "nest-winston": "^1.10.2",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "radash": "^12.1.1",
    "redlock": "5.0.0-beta.2",
    "reflect-metadata": "^0.2.2",
    "resend": "^6.10.0",
    "rxjs": "^7.8.2",
    "sharp": "^0.34.5",
    "winston": "^3.19.0",
    "winston-daily-rotate-file": "^5.0.0"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@commitlint/cz-commitlint": "^20.5.1",
    "@commitlint/prompt-cli": "^20.5.0",
    "@eslint/eslintrc": "^3.3.5",
    "@eslint/js": "^10.0.1",
    "@nestjs/cli": "^11.0.19",
    "@nestjs/schematics": "^11.0.10",
    "@swc/cli": "^0.8.1",
    "@swc/core": "^1.15.24",
    "@types/bcrypt": "^6.0.0",
    "@types/compression": "^1.8.1",
    "@types/cookie-parser": "^1.4.10",
    "@types/express": "^5.0.6",
    "@types/geoip-lite": "^1.4.4",
    "@types/multer": "^2.1.0",
    "@types/node": "^25.5.2",
    "@types/passport-jwt": "^4.0.1",
    "dotenv-expand": "^12.0.3",
    "eslint": "^10.2.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-perfectionist": "^5.8.0",
    "eslint-plugin-prettier": "^5.5.5",
    "globals": "^17.4.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "pm2": "^6.0.14",
    "prettier": "^3.8.1",
    "prettier-plugin-prisma": "^5.0.0",
    "prisma": "^7.7.0",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.1"
  }
}
