{
  "$schema": "https://json.schemastore.org/nest-cli",
  "collection": "@nestjs/schematics",
  "sourceRoot": "src",
  "compilerOptions": {
    "deleteOutDir": true,
    "watchAssets": true,
    "builder": {
      "type": "swc",
      "options": {
        "quiet": true,
        "swcrcPath": ".swcrc"
      }
    },
    "typeCheck": false,
    "assets": ["**/*.hbs", "assets/**/*"]
  }
}
